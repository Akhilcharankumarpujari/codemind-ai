# ── Required ──────────────────────────────────────────────────────────────────
# Your Groq API key — get it at https://console.groq.com
GROQ_API_KEY=gsk_YOUR_KEY_HERE

# ── Optional ──────────────────────────────────────────────────────────────────
# Port for the Express server (default: 3001)
PORT=3001

# Node environment: development | production
NODE_ENV=development

# Default model (must be in ALLOWED_MODELS in groqService.js)
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile

# Allowed frontend origins (comma-separated for multiple)
# In dev, all origins are allowed. In production, lock this down:
# FRONTEND_URL=https://your-frontend.com
FRONTEND_URL=http://localhost:5500
